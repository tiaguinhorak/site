# Copy to .env — see api-csgo/LOCAL-DEV.md
# =============================================================================
# Clutch SITE — local dev (Postgres can stay on VPS)
# =============================================================================

DATABASE_URL=postgresql://USER:PASS@HOST:5432/DATABASE?sslmode=require
SESSION_SECRET=change-me-min-32-chars-local-dev-only
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
STEAM_API_KEY=

# --- Produção (VPS) ---
# APP_URL=http://SEU_DOMINIO_OU_IP:3000
# NEXT_PUBLIC_APP_URL=http://SEU_DOMINIO_OU_IP:3000
# DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/DATABASE  (se Postgres na mesma VPS)
# Não use TUNNEL_URL / ngrok em produção.
# Depois de alterar APP_URL: npm run build && reinicie o processo (pm2/systemd).

CSGO_API_URL=http://127.0.0.1:3001
CSGO_SKINS_SYNC_KEY=clutch-dev-skins-sync-2026
CSGO_API_KEY=suachaveapi

CSGO_SERVER_HOST=127.0.0.1
CSGO_RCON_PORT=27015
CSGO_RCON_PASSWORD=clutchclube

INVENTORY_ALL_SKINS=true
CATALOG_ALLOWLIST_SOURCE=site-db
