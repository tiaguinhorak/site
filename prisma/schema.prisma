  @@unique([lobbyRoomId, userId])
  @@index([lobbyRoomId, planPriority, requestedAt])
}

model RankedQueueEntry {
  id           String   @id @default(cuid())
  partyId      String   @unique
  leaderUserId String
  playerCount  Int
  avgElo       Int
  planPriority Int      @default(0)
  status       String   @default("searching")
  joinedAt     DateTime @default(now())
