generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PREMIUM
  ELITE
}

enum NotificationType {
  SYSTEM
  MATCH
  SOCIAL
  PROMO
}

enum InventoryCategory {
  KNIFE
  GLOVES
  RIFLE
  PISTOL
  SMG
  AGENT
}

enum InventoryRarity {
  COMUM
  RARO
  EPICO
  LENDARIO
  MITICO
}

enum PunishmentType {
  BAN
  MUTE
  WARNING
  KICK
  RESTRICT
}

enum PunishmentScope {
  PLATFORM
  SERVER
}

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  passwordHash       String?
  nickname           String
  firstName          String   @default("")
  lastName           String   @default("")
  phone              String   @default("")
  country            String   @default("BR")
  bio                String   @default("")
  avatarUrl          String?
  avatarPreset       String?
  plan               Plan     @default(FREE)
  rank               Int      @default(0)
  elo                Int      @default(1000)
  kd                 Float    @default(0)
  matches            Int      @default(0)
  winRate            Int      @default(0)
  hoursPlayed        Int      @default(0)
  anticheatInstalled Boolean  @default(false)
  mfaEnabled         Boolean  @default(false)
  mfaSecret          String?
  steamId            String?  @unique
  steamLinkedAt      DateTime?
  steamPersonaName   String?
  steamAvatarUrl     String?
  steamProfileUrl    String?
  steamCountryCode   String?
  isAdmin            Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  notifications Notification[]
  inventory     UserInventoryItem[]
  punishments       Punishment[] @relation("UserPunishments")
  punishmentsIssued Punishment[] @relation("PunishmentAdmin")
  punishmentsRevoked Punishment[] @relation("PunishmentRevoker")
  adminAuditLogs    AdminAuditLog[]

  @@index([rank])
  @@index([elo])
}

model Punishment {
  id          String          @id @default(cuid())
  userId      String
  adminId     String
  type        PunishmentType
  scope       PunishmentScope @default(PLATFORM)
  serverName  String          @default("")
  reason      String
  notes       String          @default("")
  active      Boolean         @default(true)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  revokedAt   DateTime?
  revokedById String?

  user      User  @relation("UserPunishments", fields: [userId], references: [id], onDelete: Cascade)
  admin     User  @relation("PunishmentAdmin", fields: [adminId], references: [id])
  revokedBy User? @relation("PunishmentRevoker", fields: [revokedById], references: [id])

  @@index([userId, active])
  @@index([type, active])
  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  summary    String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean          @default(false)
  type      NotificationType @default(SYSTEM)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model GameMode {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  accent      String
  tagline     String         @default("")
  description String         @default("")
  iconKey     String         @default("Crosshair")
  sortOrder   Int            @default(0)
  rooms       GameModeRoom[]
}

model GameModeRoom {
  id         String   @id @default(cuid())
  gameModeId String
  name       String
  map        String
  players    Int      @default(0)
  slots      Int
  ping       Int      @default(0)
  sortOrder  Int      @default(0)

  gameMode GameMode @relation(fields: [gameModeId], references: [id], onDelete: Cascade)

  @@index([gameModeId])
}

model NewsArticle {
  id           String   @id @default(cuid())
  title        String
  excerpt      String
  category     String
  imageAccent  String
  imageUrl     String?
  featured     Boolean  @default(false)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StoreItem {
  id            String  @id @default(cuid())
  name          String
  type          String
  priceCents    Int
  originalCents Int?
  badge         String
  description   String
  accent        String
  trending      Boolean @default(false)
  featured      Boolean @default(false)
  sortOrder     Int     @default(0)
}

model InventoryItem {
  id       String            @id @default(cuid())
  name     String
  category InventoryCategory
  rarity   InventoryRarity
  accent   String
  sortOrder Int @default(0)

  users UserInventoryItem[]
}

model UserInventoryItem {
  id              String  @id @default(cuid())
  userId          String
  inventoryItemId String
  equipped        Boolean @default(false)
  owned           Boolean @default(true)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([userId, inventoryItemId])
  @@index([userId])
}

model PublicServer {
  id        String @id @default(cuid())
  name      String
  map       String
  mode      String
  players   Int    @default(0)
  slots     Int
  ping      Int    @default(0)
  sortOrder Int    @default(0)
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  rank   Int    @unique
  name   String
  kd     Float
  points Int
}

model MarketingFeature {
  id          String @id @default(cuid())
  index       String
  title       String
  description String
  iconKey     String
  sortOrder   Int    @default(0)
}

model SubscriptionPlan {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  priceCents Int
  period    String
  highlight Boolean @default(false)
  badge     String?
  features  String
  cta       String
  sortOrder Int     @default(0)
}

model SiteStat {
  id        String @id @default(cuid())
  value     String
  label     String
  sortOrder Int    @default(0)
}
