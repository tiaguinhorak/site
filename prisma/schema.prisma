// --- CS:GO REST API (integração servidor / partidas / skins) ---

enum CsgoSkinWear {
  factory_new
  minimal_wear
  field_tested
  well_worn
  battle_scarred
}

/// Gameplay tuning applied to CS servers by pool (ranked, warmup, deathmatch, ...).
/// api-csgo fetches this by pool on server start + ranked match start and applies via RCON + clutch_warmup_rules.
model ServerGameConfig {
  id                String   @id @default(cuid())
  /// Matches api-csgo server pool (e.g. "ranked", "warmup", "deathmatch").
  pool              String   @unique
  enabled           Boolean  @default(true)
  /// Warmup duration in seconds (ranked uses this instead of the old hardcoded 15s).
  warmupSeconds     Int      @default(60)
  /// Money granted during warmup only.
  warmupStartMoney  Int      @default(16000)
  warmupMaxMoney    Int      @default(16000)
  /// Allow buying anywhere / anytime during warmup.
  warmupBuyAnywhere Boolean  @default(true)
  /// Always randomize spawn points.
  randomSpawns      Boolean  @default(true)
  /// Deathmatch-style respawn on death.
  dmRespawn         Boolean  @default(false)
  gameType          Int      @default(0)
  gameMode          Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([enabled])
}

model CsgoServer {
  id            String   @id @default(uuid())
  name          String
  host          String
  sshPort       Int      @default(22)
  sshUser       String?
  sshPassword   String?
  rconPort      Int
  rconPassword  String
  csgoDir       String
  screenSession String
  status        String   @default("offline")
  port          Int
  tickrate      Int      @default(128)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matches CsgoMatch[]

  @@index([status])
}

model CsgoMatch {
  id          String   @id @default(uuid())
  roomId      String
  teamA       Json
  teamB       Json
  mapPool     Json
  vetoHistory Json     @default("[]")
  pickedMaps  Json     @default("{}")
  status      String   @default("waiting_players")
  serverId    String?
  selectedMap String?
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server CsgoServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([roomId])
  @@index([serverId])
}

model CsgoSkinCatalog {
  id             String   @id
  weaponId       String
  weaponName     String
  paintkit       Int
  paintkitName   String
  rarity         String
  category       String
  imageUrl       String?
  /**
   * CS:GO item definition index (e.g. glove type 5030). From CSGO-API weapon.weapon_id.
   */
  weaponDefIndex Int?
  /**
   * Visible in inventory and synced to game allowlist when true.
   */
  enabled        Boolean  @default(true)
  /**
   * sync | admin | import
   */
  source         String   @default("sync")
  /**
   * csgo = servidor CS:GO (!ws); cs2 = só CS2 (bloqueado); unknown = legado
   */
  gameClient     String   @default("unknown")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  playerSkins         CsgoPlayerSkin[]
  inventoryItems      InventoryItem[]
  storeRewards        StoreItemReward[]
  rankedSeasonPrizes  RankedSeasonPrize[]

  @@unique([weaponId, paintkit])
  @@index([weaponId])
  @@index([category])
  @@index([category, weaponName])
  @@index([enabled])
}

model CsgoPlayerSkin {
  id            String       @id @default(cuid())
  steamId       String
  skinId        String
  wear          CsgoSkinWear @default(factory_new)
  /// Continuous wear 0.0 (Factory New / max quality) .. 1.0 (Battle-Scarred). Preferred over `wear` enum when syncing.
  floatValue    Float        @default(0)
  seed          Int          @default(0)
  stattrak      Boolean      @default(false)
  stattrakCount Int          @default(0)
  nametag       String?
  equipped      Boolean      @default(false)
  equippedT     Boolean      @default(false)
  equippedCT    Boolean      @default(false)
  createdAt     DateTime     @default(now())

  skin CsgoSkinCatalog @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@index([steamId])
  @@index([steamId, equipped])
  @@index([steamId, equippedT])
  @@index([steamId, equippedCT])
}

model CsgoStickerCatalog {
