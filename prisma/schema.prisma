generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PREMIUM
  ELITE
}

enum AvatarModerationStatus {
  APPROVED
  PENDING
  REJECTED
}

enum AvatarMediaType {
  STATIC
  GIF
}

enum SmurfStatus {
  CLEAR
  REVIEW
  FLAGGED
  CONFIRMED
}

enum SmurfSignalType {
  NEW_STEAM_ACCOUNT
  LOW_STEAM_AGE
  SHARED_IP
  STAT_ANOMALY
  STEAM_RELINK
  RAPID_RANK_CLIMB
}

enum NotificationType {
  SYSTEM
  MATCH
  SOCIAL
  PROMO
}

enum InventoryCategory {
  KNIFE
  GLOVES
  RIFLE
  PISTOL
  SMG
  AGENT
}

enum InventoryRarity {
  COMUM
  RARO
  EPICO
  LENDARIO
  MITICO
}

enum PunishmentType {
  BAN
  MUTE
  WARNING
  KICK
  RESTRICT
}

enum PunishmentScope {
  PLATFORM
  SERVER
}

enum StoreProductKind {
  SKIN
  PACKAGE
  CASE
  AGENT
  TAG
  MEDAL
  SUBSCRIPTION
}

enum StoreRewardKind {
  CATALOG_SKIN
  AGENT
  STICKER
}

enum StorePurchaseStatus {
  COMPLETED
  FAILED
  REFUNDED
}

enum StoreCheckoutStatus {
  PENDING
  PAID
  DELINQUENT
  CANCELLED
}

enum CoinTransactionKind {
  EARN_MATCH
  EARN_MISSION
  EARN_ACHIEVEMENT
  EARN_BATTLEPASS
  PURCHASE
  GIFT_SENT
  GIFT_RECEIVED
  ADMIN_ADJUST
  REFUND
  COIN_TOPUP
}

enum MissionPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum MissionMetric {
  MATCHES_PLAYED
  MATCHES_WON
  KILLS
  ASSISTS
  MVPS
}

enum AchievementMetric {
  TOTAL_MATCHES
  TOTAL_WINS
  TOTAL_KILLS
  TOTAL_ASSISTS
  TOTAL_MVPS
  LEVEL
  LIFETIME_COINS
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum BattlePassTrack {
  FREE
  PREMIUM
}

enum BattlePassRewardType {
  COINS
  SKIN
  AGENT
  STICKER
}

enum ClanRole {
  OWNER
  OFFICER
  MEMBER
}

enum ClanJoinMode {
  OPEN
  CLOSED
}

enum ClanJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CoinPackCheckoutStatus {
  PENDING
  PAID
  CANCELLED
  DELINQUENT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum MatchHighlightType {
  ACE
  CLUTCH
  MULTI_KILL
  HEADSHOTS
  ENTRY
  KNIFE
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  passwordHash          String?
  nickname              String
  firstName             String    @default("")
  lastName              String    @default("")
  phone                 String    @default("")
  country               String    @default("BR")
  bio                   String    @default("")
  avatarUrl             String?
  avatarPreset          String?
  plan                  Plan      @default(FREE)
  rank                  Int       @default(0)
  elo                   Int       @default(1000)
  kd                    Float     @default(0)
  matches               Int       @default(0)
  winRate               Int       @default(0)
  hoursPlayed           Int       @default(0)
  anticheatInstalled    Boolean   @default(false)
  mfaEnabled            Boolean   @default(false)
  mfaSecret             String?
  steamId               String?   @unique
  steamLinkedAt         DateTime?
  steamPersonaName      String?
  steamAvatarUrl        String?
  steamProfileUrl       String?
  steamCountryCode      String?
  discordUserId         String?   @unique
  discordUsername       String?
  discordLinkedAt       DateTime?
  isAdmin               Boolean   @default(false)
  rankedQueueDodges     Int       @default(0)
  rankedRestrictedUntil DateTime?
  rankedLastDodgeAt     DateTime?
  rankedWins            Int       @default(0)
  rankedLosses          Int       @default(0)
  rankedKills           Int       @default(0)
  rankedDeaths          Int       @default(0)
  rankedAssists         Int       @default(0)
  rankedMvps            Int       @default(0)
  rankedHeadshots       Int       @default(0)
  rankedDamage          Int       @default(0)
  rankedRoundsPlayed    Int       @default(0)
  rankedClutches        Int       @default(0)
  rankedUtilityDamage   Int       @default(0)
  rankedEnemiesFlashed  Int       @default(0)
  rankedAwpKills        Int       @default(0)
  profileTag            String?
  profileMedalCode      String?
  profileBannerUrl      String?
  profileBannerMediaType AvatarMediaType       @default(STATIC)
  profileBannerModerationStatus AvatarModerationStatus @default(APPROVED)
  profileBackgroundId   String                @default("default")
  profileFrameId        String                @default("none")
  profileFrameColor     String?
  profileAccentColor    String?
  profileThemeId        String                @default("aurora")
  profileThemeColor     String?
  profileBorderId       String                @default("none")
  profileBorderColor    String?
  profileBackgroundColor String?
  profileShowPlanBadge  Boolean               @default(true)
  profileShowAchievements Boolean             @default(true)
  avatarModerationStatus AvatarModerationStatus @default(APPROVED)
  avatarMediaType       AvatarMediaType       @default(STATIC)
  steamAccountCreatedAt DateTime?
  rankedSmurfHoldUntil  DateTime?
  smurfRiskScore        Int                   @default(0)
  smurfStatus           SmurfStatus           @default(CLEAR)
  mapPlayCounts         Json                  @default("{}")
  weaponKillCounts      Json      @default("{}")
  competitivePoints     Int       @default(0)
  xp                    Int       @default(0)
  level                 Int       @default(1)
  coins                 Int       @default(0)
  lifetimeCoins         Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  notifications           Notification[]
  inventory               UserInventoryItem[]
  punishments             Punishment[]                 @relation("UserPunishments")
  punishmentsIssued       Punishment[]                 @relation("PunishmentAdmin")
  punishmentsRevoked      Punishment[]                 @relation("PunishmentRevoker")
  adminAuditLogs          AdminAuditLog[]
  hostedLobbyRooms        LobbyRoom[]                  @relation("LobbyHost")
  lobbyMemberships        LobbyMember[]
  rankedPartiesLed        RankedParty[]                @relation("RankedPartyLeader")
  rankedPartyMembers      RankedPartyMember[]
  rankedPartyMessages     RankedPartyMessage[]
  rankedMatchAcceptances  RankedMatchAcceptance[]
  rankedMapVotes          RankedMapVote[]
  rankedMatchPlayerStats  RankedMatchPlayerStat[]
  lobbyJoinQueues         LobbyJoinQueue[]
  rankedQueueEntries      RankedQueueEntry[]           @relation("RankedQueueLeader")
  notificationPreferences UserNotificationPreferences?
  newsArticlesAuthored    NewsArticle[]                @relation("NewsAuthor")
  storePurchases          StorePurchase[]
  storeCart               StoreCart?
  storeCheckouts          StoreCheckout[]
  coinTransactions        CoinTransaction[]
  userMissions            UserMission[]
  userAchievements        UserAchievement[]
  battlePasses            UserBattlePass[]
  battlePassClaims        UserBattlePassClaim[]
  clanMembership          ClanMember?
  clansOwned              Clan[]                       @relation("ClanOwner")
  clanJoinRequests        ClanJoinRequest[]
  coinPackCheckouts       CoinPackCheckout[]
  friendRequestsSent      Friendship[]                 @relation("FriendRequester")
  friendRequestsReceived  Friendship[]                 @relation("FriendAddressee")
  smurfSignals            SmurfSignal[]
  accountFingerprints     AccountFingerprint[]

  @@index([rank])
  @@index([elo])
  @@index([competitivePoints])
  @@index([level])
  @@index([rankedKills])
  @@index([rankedAssists])
  @@index([rankedMvps])
  @@index([rankedHeadshots])
  @@index([rankedClutches])
  @@index([rankedUtilityDamage])
  @@index([rankedAwpKills])
  @@index([smurfStatus])
  @@index([smurfRiskScore])
  @@index([avatarModerationStatus])
}

model SmurfSignal {
  id         String          @id @default(cuid())
  userId     String
  signalType SmurfSignalType
  score      Int             @default(1)
  metadata   Json            @default("{}")
  resolved   Boolean         @default(false)
  createdAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resolved])
  @@index([signalType, createdAt])
}

model AccountFingerprint {
  id            String   @id @default(cuid())
  userId        String
  ipHash        String
  userAgentHash String
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipHash, userAgentHash])
  @@index([ipHash])
  @@index([userAgentHash])
}

model CoinTransaction {
  id           String              @id @default(cuid())
  userId       String
  amount       Int
  balanceAfter Int
  kind         CoinTransactionKind
  reason       String              @default("")
  metadata     Json?
  createdAt    DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([kind])
}

model MissionDefinition {
  id          String        @id @default(cuid())
  code        String        @unique
  period      MissionPeriod
  metric      MissionMetric
  target      Int
  title       String
  description String        @default("")
  rewardXp    Int           @default(0)
  rewardCoins Int           @default(0)
  icon        String?
  sortOrder   Int           @default(0)
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userMissions UserMission[]

  @@index([period, enabled])
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  missionId   String
  periodKey   String
  progress    Int       @default(0)
  target      Int
  completed   Boolean   @default(false)
  claimed     Boolean   @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission MissionDefinition @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, periodKey])
  @@index([userId, periodKey])
}

model AchievementDefinition {
  id          String            @id @default(cuid())
  code        String            @unique
  metric      AchievementMetric
  threshold   Int
  tier        AchievementTier   @default(BRONZE)
  title       String
  description String            @default("")
  rewardXp    Int               @default(0)
  rewardCoins Int               @default(0)
  icon        String?
  sortOrder   Int               @default(0)
  enabled     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userAchievements UserAchievement[]

  @@index([metric, enabled])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model BattlePassSeason {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  seasonNumber     Int       @default(1)
  maxLevel         Int       @default(50)
  xpPerLevel       Int       @default(1000)
  premiumCostCoins Int       @default(5000)
  startsAt         DateTime  @default(now())
  endsAt           DateTime?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rewards    BattlePassReward[]
  userPasses UserBattlePass[]

  @@index([active])
}

model BattlePassReward {
  id              String               @id @default(cuid())
  seasonId        String
  level           Int
  track           BattlePassTrack
  rewardType      BattlePassRewardType
  amountCoins     Int                  @default(0)
  catalogSkinId   String?
  agentDefIndex   Int?
  stickerDefIndex Int?
  label           String
  icon            String?
  createdAt       DateTime             @default(now())

  season BattlePassSeason      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  claims UserBattlePassClaim[]

  @@unique([seasonId, level, track])
  @@index([seasonId])
}

model UserBattlePass {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  xp        Int      @default(0)
  level     Int      @default(1)
  premium   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  season BattlePassSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId])
}

model UserBattlePassClaim {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  claimedAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward BattlePassReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
}

model Punishment {
  id          String          @id @default(cuid())
  userId      String
  adminId     String
  type        PunishmentType
  scope       PunishmentScope @default(PLATFORM)
  serverName  String          @default("")
  reason      String
  notes       String          @default("")
  active      Boolean         @default(true)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  revokedAt   DateTime?
  revokedById String?

  user      User  @relation("UserPunishments", fields: [userId], references: [id], onDelete: Cascade)
  admin     User  @relation("PunishmentAdmin", fields: [adminId], references: [id])
  revokedBy User? @relation("PunishmentRevoker", fields: [revokedById], references: [id])

  @@index([userId, active])
  @@index([type, active])
  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  summary    String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  title        String
  body         String
  titleKey     String?
  bodyKey      String?
  params       Json?
  translations Json?
  read         Boolean          @default(false)
  type         NotificationType @default(SYSTEM)
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model UserNotificationPreferences {
  userId          String  @id
  emailNewsletter Boolean @default(true)
  inAppMatch      Boolean @default(true)
  inAppSocial     Boolean @default(true)
  inAppPromo      Boolean @default(true)
  inAppSystem     Boolean @default(true)
  browserPush     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameMode {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  accent      String
  tagline     String         @default("")
  description String         @default("")
  iconKey     String         @default("Crosshair")
  sortOrder   Int            @default(0)
  rooms       GameModeRoom[]
  lobbyRooms  LobbyRoom[]
}

model GameModeRoom {
  id         String @id @default(cuid())
  gameModeId String
  name       String
  map        String
  players    Int    @default(0)
  slots      Int
  ping       Int    @default(0)
  sortOrder  Int    @default(0)

  gameMode  GameMode   @relation(fields: [gameModeId], references: [id], onDelete: Cascade)
  lobbyRoom LobbyRoom?

  @@index([gameModeId])
}

model LobbyRoom {
  id            String    @id @default(cuid())
  hostUserId    String
  gameModeId    String
  catalogRoomId String?   @unique
  isSystem      Boolean   @default(false)
  name          String
  map           String
  slots         Int
  region        String    @default("BR")
  visibility    String    @default("public")
  passwordHash  String?
  settings      Json      @default("{}")
  status        String    @default("open")
  ping          Int       @default(25)
  matchId       String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  host        User                @relation("LobbyHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  gameMode    GameMode            @relation(fields: [gameModeId], references: [id], onDelete: Cascade)
  catalogRoom GameModeRoom?       @relation(fields: [catalogRoomId], references: [id], onDelete: Cascade)
  members     LobbyMember[]
  joinQueue   LobbyJoinQueue[]
  rankedMatch RankedMatchSession?

  @@index([status])
  @@index([gameModeId])
  @@index([hostUserId])
  @@index([createdAt])
  @@index([isSystem])
}

model RankedParty {
  id           String   @id @default(cuid())
  leaderUserId String
  inviteCode   String   @unique @default(cuid())
  status       String   @default("open")
  name         String?
  region       String   @default("BR")
  visibility   String   @default("public")
  passwordHash String?
  minLevel     Int      @default(1)
  maxLevel     Int      @default(20)
  mapPool      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leader             User                  @relation("RankedPartyLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  members            RankedPartyMember[]
  challengesSent     RankedChallenge[]     @relation("ChallengeFrom")
  challengesReceived RankedChallenge[]     @relation("ChallengeTo")
  matchSessionsAsA   RankedMatchSession[]  @relation("MatchPartyA")
  matchSessionsAsB   RankedMatchSession[]  @relation("MatchPartyB")
  queueEntry         RankedQueueEntry?
  activities         RankedPartyActivity[]
  messages           RankedPartyMessage[]

  @@index([leaderUserId])
  @@index([status])
}

model RankedPartyActivity {
  id            String   @id @default(cuid())
  partyId       String
  type          String
  nickname      String
  actorNickname String?
  createdAt     DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
}

model RankedPartyMessage {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  nickname  String
  body      String
  createdAt DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
}

model RankedPartyMember {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  slotIndex Int
  joinedAt  DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@unique([partyId, slotIndex])
  @@unique([userId])
  @@index([partyId])
}

model RankedChallenge {
  id          String    @id @default(cuid())
  fromPartyId String
  toPartyId   String
  status      String    @default("pending")
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  fromParty    RankedParty         @relation("ChallengeFrom", fields: [fromPartyId], references: [id], onDelete: Cascade)
  toParty      RankedParty         @relation("ChallengeTo", fields: [toPartyId], references: [id], onDelete: Cascade)
  matchSession RankedMatchSession?

  @@index([fromPartyId])
  @@index([toPartyId])
  @@index([status])
}

model RankedMatchSession {
  id              String    @id @default(cuid())
  challengeId     String?   @unique
  lobbyRoomId     String?   @unique
  matchSource     String    @default("challenge")
  teamSize        Int       @default(5)
  partyAId        String
  partyBId        String
  status          String    @default("accepting")
  csgoMatchId     String?
  csgoServerId    String?
  selectedMap     String?
  serverHost      String?
  serverPort      Int?
  vetoData        Json?
  voteEndsAt      DateTime?
  scoreTeamA      Int?
  scoreTeamB      Int?
  winnerTeam      String?
  liveStartedAt   DateTime?
  matchFinishedAt DateTime?
  durationSec     Int?
  resultSyncedAt  DateTime?
  demoUrl         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  challenge   RankedChallenge?        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  lobbyRoom   LobbyRoom?              @relation(fields: [lobbyRoomId], references: [id], onDelete: SetNull)
  partyA      RankedParty             @relation("MatchPartyA", fields: [partyAId], references: [id], onDelete: Cascade)
  partyB      RankedParty             @relation("MatchPartyB", fields: [partyBId], references: [id], onDelete: Cascade)
  acceptances RankedMatchAcceptance[]
  mapVotes    RankedMapVote[]
  playerStats RankedMatchPlayerStat[]
  rounds      RankedMatchRound[]
  highlights  RankedMatchHighlight[]
  deaths      RankedMatchDeath[]

  @@index([partyAId])
  @@index([partyBId])
  @@index([status])
  @@index([lobbyRoomId])
  @@index([csgoServerId])
}

model RankedMatchAcceptance {
  id         String    @id @default(cuid())
  sessionId  String
  userId     String
  accepted   Boolean   @default(false)
  acceptedAt DateTime?

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model RankedMapVote {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  map       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model RankedMatchPlayerStat {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  steamId   String
  team      String
  kills          Int      @default(0)
  deaths         Int      @default(0)
  assists        Int      @default(0)
  score          Int      @default(0)
  mvp            Int      @default(0)
  won            Boolean  @default(false)
  headshots      Int      @default(0)
  damage         Int      @default(0)
  utilityDamage  Int      @default(0)
  enemiesFlashed Int      @default(0)
  clutchesWon    Int      @default(0)
  entryKills     Int      @default(0)
  awpKills       Int      @default(0)
  createdAt      DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([sessionId, steamId])
  @@index([sessionId])
  @@index([userId])
  @@index([steamId])
}

model RankedMatchRound {
  id          String   @id @default(cuid())
  sessionId   String
  roundNumber Int
  winnerTeam  String?
  reason      String?
  bombPlanted Boolean  @default(false)
  createdAt   DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roundNumber])
  @@index([sessionId])
}

model RankedMatchHighlight {
  id          String             @id @default(cuid())
  sessionId   String
  steamId     String
  userId      String?
  type        MatchHighlightType
  roundNumber Int?
  detail      String             @default("")
  createdAt   DateTime           @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model RankedMatchDeath {
  id            String   @id @default(cuid())
  sessionId     String
  roundNumber   Int      @default(0)
  victimSteamId String
  killerSteamId String?
  weapon        String?
  headshot      Boolean  @default(false)
  victimTeam    String?
  x             Float    @default(0)
  y             Float    @default(0)
  z             Float    @default(0)
  createdAt     DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, roundNumber])
}

model LobbyMember {
  id          String   @id @default(cuid())
  lobbyRoomId String
  userId      String
  slotIndex   Int
  isReady     Boolean  @default(false)
  joinedAt    DateTime @default(now())

  lobbyRoom LobbyRoom @relation(fields: [lobbyRoomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyRoomId, userId])
  @@unique([lobbyRoomId, slotIndex])
  @@unique([userId])
  @@index([lobbyRoomId])
  @@index([userId])
}

model LobbyJoinQueue {
  id           String   @id @default(cuid())
  lobbyRoomId  String
  userId       String
  planPriority Int      @default(0)
  requestedAt  DateTime @default(now())

  lobbyRoom LobbyRoom @relation(fields: [lobbyRoomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyRoomId, userId])
  @@index([lobbyRoomId, planPriority, requestedAt])
}

model RankedQueueEntry {
  id           String   @id @default(cuid())
  partyId      String   @unique
  leaderUserId String
  playerCount  Int
  avgElo       Int
  planPriority Int      @default(0)
  status       String   @default("searching")
  joinedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  party  RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  leader User        @relation("RankedQueueLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)

  @@index([status, joinedAt])
  @@index([leaderUserId])
}

model NewsArticle {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  excerpt      String
  body         String    @default("") @db.Text
  category     String
  imageAccent  String
  imageUrl     String?
  featured     Boolean   @default(false)
  translations Json?
  archivedAt   DateTime?
  authorId     String?
  publishedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author User? @relation("NewsAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([publishedAt])
  @@index([authorId])
  @@index([archivedAt])
}

model StoreItem {
  id            String           @id @default(cuid())
  name          String
  type          String
  productKind   StoreProductKind @default(SKIN)
  priceCents    Int
  originalCents Int?
  coinPrice     Int?
  coinShopOnly  Boolean          @default(false)
  badge         String
  description   String
  accent        String
  imageUrl      String?
  enabled       Boolean          @default(true)
  trending      Boolean          @default(false)
  featured      Boolean          @default(false)
  sortOrder     Int              @default(0)
  maxPerUser    Int?
  tagText       String?
  medalCode     String?
  grantPlan     Plan?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  rewards       StoreItemReward[]
  purchases     StorePurchase[]
  cartItems     StoreCartItem[]
  checkoutItems StoreCheckoutItem[]

  @@index([enabled, sortOrder])
}

model StoreItemReward {
  id              String          @id @default(cuid())
  storeItemId     String
  kind            StoreRewardKind
  catalogSkinId   String?
  agentDefIndex   Int?
  stickerDefIndex Int?
  weight          Int             @default(100)
  quantity        Int             @default(1)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  storeItem   StoreItem        @relation(fields: [storeItemId], references: [id], onDelete: Cascade)
  catalogSkin CsgoSkinCatalog? @relation(fields: [catalogSkinId], references: [id], onDelete: SetNull)

  @@index([storeItemId])
  @@index([catalogSkinId])
}

model StorePurchase {
  id             String              @id @default(cuid())
  userId         String
  storeItemId    String
  priceCents     Int
  status         StorePurchaseStatus @default(COMPLETED)
  grantedRewards Json?
  createdAt      DateTime            @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([storeItemId])
  @@index([userId, storeItemId])
}

model StoreCart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items StoreCartItem[]
}

model StoreCartItem {
  id          String   @id @default(cuid())
  cartId      String
  storeItemId String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart      StoreCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@unique([cartId, storeItemId])
  @@index([cartId])
}

model StoreCheckout {
  id           String              @id @default(cuid())
  userId       String
  status       StoreCheckoutStatus @default(PENDING)
  totalCents   Int
  dueAt        DateTime
  paidAt       DateTime?
  delinquentAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items StoreCheckoutItem[]

  @@index([userId, status])
  @@index([status, dueAt])
}

model StoreCheckoutItem {
  id             String @id @default(cuid())
  checkoutId     String
  storeItemId    String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  grantedRewards Json?

  checkout  StoreCheckout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  storeItem StoreItem     @relation(fields: [storeItemId], references: [id], onDelete: Restrict)

  @@index([checkoutId])
}

model InventoryItem {
  id            String            @id @default(cuid())
  name          String
  category      InventoryCategory
  rarity        InventoryRarity
  accent        String
  sortOrder     Int               @default(0)
  catalogSkinId String?
  imageUrl      String?

  catalogSkin CsgoSkinCatalog?    @relation(fields: [catalogSkinId], references: [id], onDelete: SetNull)
  users       UserInventoryItem[]

  @@index([catalogSkinId])
}

model UserInventoryItem {
  id              String  @id @default(cuid())
  userId          String
  inventoryItemId String
  equipped        Boolean @default(false)
  owned           Boolean @default(true)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([userId, inventoryItemId])
  @@index([userId])
}

model PublicServer {
  id           String  @id @default(cuid())
  name         String
  map          String
  mode         String
  players      Int     @default(0)
  slots        Int
  ping         Int     @default(0)
  sortOrder    Int     @default(0)
  csgoServerId String? @unique
  host         String?
  port         Int?
  isLiveSynced Boolean @default(false)
  pool         String  @default("public")

  @@index([isLiveSynced])
  @@index([isLiveSynced, pool])
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  rank   Int    @unique
  name   String
  kd     Float
  points Int
}

model MarketingFeature {
  id          String @id @default(cuid())
  index       String
  title       String
  description String
  iconKey     String
  sortOrder   Int    @default(0)
}

model SubscriptionPlan {
  id         String  @id @default(cuid())
  slug       String  @unique
  name       String
  priceCents Int
  period     String
  highlight  Boolean @default(false)
  badge      String?
  features   String
  cta        String
  sortOrder  Int     @default(0)
}

model SiteStat {
  id        String @id @default(cuid())
  value     String
  label     String
  sortOrder Int    @default(0)
}

model DiscordLinkCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discordUserId   String
  discordUsername String    @default("")
  expiresAt       DateTime
  usedAt          DateTime?
  userId          String?
  createdAt       DateTime  @default(now())

  @@index([discordUserId])
  @@index([expiresAt])
}

model DiscordFeedPublishLog {
  id          String   @id @default(cuid())
  feedType    String
  itemKey     String
  publishedAt DateTime @default(now())

  @@unique([feedType, itemKey])
  @@index([feedType])
}

model DiscordBotFeedChannel {
  id              String    @id @default(cuid())
  guildId         String
  feedType        String
  channelId       String
  enabled         Boolean   @default(true)
  intervalMinutes Int       @default(60)
  lastRunAt       DateTime?
  lastMessageId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([guildId, feedType])
  @@index([guildId])
}

// --- CS:GO REST API (integração servidor / partidas / skins) ---

enum CsgoSkinWear {
  factory_new
  minimal_wear
  field_tested
  well_worn
  battle_scarred
}

model CsgoServer {
  id            String   @id @default(uuid())
  name          String
  host          String
  sshPort       Int      @default(22)
  sshUser       String?
  sshPassword   String?
  rconPort      Int
  rconPassword  String
  csgoDir       String
  screenSession String
  status        String   @default("offline")
  port          Int
  tickrate      Int      @default(128)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matches CsgoMatch[]

  @@index([status])
}

model CsgoMatch {
  id          String   @id @default(uuid())
  roomId      String
  teamA       Json
  teamB       Json
  mapPool     Json
  vetoHistory Json     @default("[]")
  pickedMaps  Json     @default("{}")
  status      String   @default("waiting_players")
  serverId    String?
  selectedMap String?
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server CsgoServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([roomId])
  @@index([serverId])
}

model CsgoSkinCatalog {
  id             String   @id
  weaponId       String
  weaponName     String
  paintkit       Int
  paintkitName   String
  rarity         String
  category       String
  imageUrl       String?
  /**
   * CS:GO item definition index (e.g. glove type 5030). From CSGO-API weapon.weapon_id.
   */
  weaponDefIndex Int?
  /**
   * Visible in inventory and synced to game allowlist when true.
   */
  enabled        Boolean  @default(true)
  /**
   * sync | admin | import
   */
  source         String   @default("sync")
  /**
   * csgo = servidor CS:GO (!ws); cs2 = só CS2 (bloqueado); unknown = legado
   */
  gameClient     String   @default("unknown")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  playerSkins    CsgoPlayerSkin[]
  inventoryItems InventoryItem[]
  storeRewards   StoreItemReward[]

  @@unique([weaponId, paintkit])
  @@index([weaponId])
  @@index([category])
  @@index([category, weaponName])
  @@index([enabled])
}

model CsgoPlayerSkin {
  id            String       @id @default(cuid())
  steamId       String
  skinId        String
  wear          CsgoSkinWear @default(field_tested)
  seed          Int          @default(0)
  stattrak      Boolean      @default(false)
  stattrakCount Int          @default(0)
  nametag       String?
  equipped      Boolean      @default(false)
  equippedT     Boolean      @default(false)
  equippedCT    Boolean      @default(false)
  createdAt     DateTime     @default(now())

  skin CsgoSkinCatalog @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@index([steamId])
  @@index([steamId, equipped])
  @@index([steamId, equippedT])
  @@index([steamId, equippedCT])
}

model CsgoStickerCatalog {
  id          String   @id
  defIndex    Int      @unique
  name        String
  imageUrl    String?
  rarity      String
  stickerType String?
  effect      String?
  tournament  String?
  enabled     Boolean  @default(true)
  source      String   @default("import")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

model CsgoPlayerWeaponSticker {
  id        String   @id @default(cuid())
  steamId   String
  weaponId  String
  team      String
  slot0     Int      @default(0)
  slot1     Int      @default(0)
  slot2     Int      @default(0)
  slot3     Int      @default(0)
  slot4     Int      @default(0)
  wear0     Float    @default(0)
  wear1     Float    @default(0)
  wear2     Float    @default(0)
  wear3     Float    @default(0)
  wear4     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([steamId, weaponId, team])
  @@index([steamId])
}

model CsgoAgentCatalog {
  id          String   @id
  defIndex    Int      @unique
  name        String
  imageUrl    String?
  rarity      String
  team        String
  modelPlayer String?
  collection  String?
  enabled     Boolean  @default(true)
  source      String   @default("import")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([team])
}

model CsgoPlayerAgent {
  id        String   @id @default(cuid())
  steamId   String   @unique
  agentT    Int      @default(0)
  agentCT   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([steamId])
}

model Clan {
  id          String       @id @default(cuid())
  tag         String       @unique
  name        String       @unique
  description String       @default("")
  avatarUrl   String?
  joinMode    ClanJoinMode @default(OPEN)
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner        User              @relation("ClanOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ClanMember[]
  joinRequests ClanJoinRequest[]

  @@index([ownerId])
}

model ClanJoinRequest {
  id        String                @id @default(cuid())
  clanId    String
  userId    String
  status    ClanJoinRequestStatus @default(PENDING)
  message   String                @default("")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId, status])
  @@index([userId])
}

model CoinPackCheckout {
  id         String                 @id @default(cuid())
  userId     String
  packId     String
  coins      Int
  priceCents Int
  status     CoinPackCheckoutStatus @default(PENDING)
  dueAt      DateTime
  paidAt     DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ClanMember {
  id       String   @id @default(cuid())
  clanId   String
  userId   String   @unique
  role     ClanRole @default(MEMBER)
  joinedAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@index([userId])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}
