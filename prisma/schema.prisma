generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PREMIUM
  ELITE
}

enum AvatarModerationStatus {
  APPROVED
  PENDING
  REJECTED
}

enum AvatarMediaType {
  STATIC
  GIF
}

enum SmurfStatus {
  CLEAR
  REVIEW
  FLAGGED
  CONFIRMED
}

enum SmurfSignalType {
  NEW_STEAM_ACCOUNT
  LOW_STEAM_AGE
  SHARED_IP
  STAT_ANOMALY
  STEAM_RELINK
  RAPID_RANK_CLIMB
}

enum NotificationType {
  SYSTEM
  MATCH
  SOCIAL
  PROMO
}

enum InventoryCategory {
  KNIFE
  GLOVES
  RIFLE
  PISTOL
  SMG
  AGENT
}

enum InventoryRarity {
  COMUM
  RARO
  EPICO
  LENDARIO
  MITICO
}

enum PunishmentType {
  BAN
  MUTE
  WARNING
  KICK
  RESTRICT
}

enum PunishmentScope {
  PLATFORM
  SERVER
}

enum AnticheatReviewStatus {
  PENDING
  UNDER_REVIEW
  CLEARED
  CONFIRMED
  DISMISSED
}

enum StoreProductKind {
  SKIN
  PACKAGE
  CASE
  AGENT
  TAG
  MEDAL
  SUBSCRIPTION
}

enum StoreRewardKind {
  CATALOG_SKIN
  AGENT
  STICKER
}

enum StorePurchaseStatus {
  COMPLETED
  FAILED
  REFUNDED
}

enum StoreCheckoutStatus {
  PENDING
  PAID
  DELINQUENT
  CANCELLED
}

enum CoinTransactionKind {
  EARN_MATCH
  EARN_MISSION
  EARN_ACHIEVEMENT
  EARN_BATTLEPASS
  EARN_SEASON_PRIZE
  PURCHASE
  GIFT_SENT
  GIFT_RECEIVED
  ADMIN_ADJUST
  REFUND
  COIN_TOPUP
}

enum MissionPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum MissionMetric {
  MATCHES_PLAYED
  MATCHES_WON
  KILLS
  ASSISTS
  MVPS
}

enum AchievementMetric {
  TOTAL_MATCHES
  TOTAL_WINS
  TOTAL_KILLS
  TOTAL_ASSISTS
  TOTAL_MVPS
  LEVEL
  LIFETIME_COINS
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum BattlePassTrack {
  FREE
  PREMIUM
}

enum BattlePassRewardType {
  COINS
  SKIN
  AGENT
  STICKER
}

enum RankedSeasonStatus {
  DRAFT
  ACTIVE
  ENDED
  ARCHIVED
}

enum RankedSeasonPixPayoutStatus {
  PENDING
  READY
  CONTACTED
  PAID
  CANCELLED
}

enum RankedSeasonRewardType {
  COINS
  PIX
  CATALOG_SKIN
  AGENT
  STICKER
}

enum ClanRole {
  OWNER
  OFFICER
  MEMBER
}

enum ClanJoinMode {
  OPEN
  CLOSED
}

enum ClanJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CoinPackCheckoutStatus {
  PENDING
  PAID
  CANCELLED
  DELINQUENT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum MatchHighlightType {
  ACE
  CLUTCH
  MULTI_KILL
  HEADSHOTS
  ENTRY
  KNIFE
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  passwordHash          String?
  nickname              String
  firstName             String    @default("")
  lastName              String    @default("")
  phone                 String    @default("")
  country               String    @default("BR")
  bio                   String    @default("")
  avatarUrl             String?
  avatarPreset          String?
  plan                  Plan      @default(FREE)
  rank                  Int       @default(0)
  elo                   Int       @default(1000)
  kd                    Float     @default(0)
  matches               Int       @default(0)
  winRate               Int       @default(0)
  hoursPlayed           Int       @default(0)
  anticheatInstalled    Boolean   @default(false)
  mfaEnabled            Boolean   @default(false)
  mfaSecret             String?
  steamId               String?   @unique
  steamLinkedAt         DateTime?
  steamPersonaName      String?
  steamAvatarUrl        String?
  steamProfileUrl       String?
  steamCountryCode      String?
  discordUserId         String?   @unique
  discordUsername       String?
  discordLinkedAt       DateTime?
  pixKey                String    @default("")
  pixKeyType            String    @default("")
  pixKeyHolderName      String    @default("")
  pixContactEmail       String    @default("")
  pixContactPhone       String    @default("")
  pixLgpdConsentedAt    DateTime?
  isAdmin               Boolean   @default(false)
  rankedQueueDodges     Int       @default(0)
  rankedRestrictedUntil DateTime?
  rankedLastDodgeAt     DateTime?
  rankedWins            Int       @default(0)
  rankedLosses          Int       @default(0)
  rankedKills           Int       @default(0)
  rankedDeaths          Int       @default(0)
  rankedAssists         Int       @default(0)
  rankedMvps            Int       @default(0)
  rankedHeadshots       Int       @default(0)
  rankedDamage          Int       @default(0)
  rankedRoundsPlayed    Int       @default(0)
  rankedClutches        Int       @default(0)
  rankedUtilityDamage   Int       @default(0)
  rankedEnemiesFlashed  Int       @default(0)
  rankedAwpKills        Int       @default(0)
  profileTag            String?
  profileMedalCode      String?
  profileBannerUrl      String?
  profileBannerMediaType AvatarMediaType       @default(STATIC)
  profileBannerModerationStatus AvatarModerationStatus @default(APPROVED)
  profileBackgroundId   String                @default("default")
  profileFrameId        String                @default("none")
  profileFrameColor     String?
  profileAccentColor    String?
  profileThemeId        String                @default("aurora")
  profileThemeColor     String?
  profileBorderId       String                @default("none")
  profileBorderColor    String?
  profileBackgroundColor String?
  profileShowPlanBadge  Boolean               @default(true)
  profileShowAchievements Boolean             @default(true)
  avatarModerationStatus AvatarModerationStatus @default(APPROVED)
  avatarMediaType       AvatarMediaType       @default(STATIC)
  steamAccountCreatedAt DateTime?
  rankedSmurfHoldUntil  DateTime?
  smurfRiskScore        Int                   @default(0)
  smurfStatus           SmurfStatus           @default(CLEAR)
  mapPlayCounts         Json                  @default("{}")
  weaponKillCounts      Json      @default("{}")
  competitivePoints     Int       @default(0)
  xp                    Int       @default(0)
  level                 Int       @default(1)
  coins                 Int       @default(0)
  lifetimeCoins         Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  notifications           Notification[]
  inventory               UserInventoryItem[]
  punishments             Punishment[]                 @relation("UserPunishments")
  punishmentsIssued       Punishment[]                 @relation("PunishmentAdmin")
  punishmentsRevoked      Punishment[]                 @relation("PunishmentRevoker")
  adminAuditLogs          AdminAuditLog[]
  hostedLobbyRooms        LobbyRoom[]                  @relation("LobbyHost")
  lobbyMemberships        LobbyMember[]
  rankedPartiesLed        RankedParty[]                @relation("RankedPartyLeader")
  rankedPartyMembers      RankedPartyMember[]
  rankedPartyMessages     RankedPartyMessage[]
  rankedMatchAcceptances  RankedMatchAcceptance[]
  rankedMapVotes          RankedMapVote[]
  rankedMatchPlayerStats  RankedMatchPlayerStat[]
  lobbyJoinQueues         LobbyJoinQueue[]
  rankedQueueEntries      RankedQueueEntry[]           @relation("RankedQueueLeader")
  notificationPreferences UserNotificationPreferences?
  newsArticlesAuthored    NewsArticle[]                @relation("NewsAuthor")
  storePurchases          StorePurchase[]
  economyGrants           UserEconomyGrant[]
  storeCart               StoreCart?
  storeCheckouts          StoreCheckout[]
  coinTransactions        CoinTransaction[]
  userMissions            UserMission[]
  userAchievements        UserAchievement[]
  battlePasses            UserBattlePass[]
  battlePassClaims        UserBattlePassClaim[]
  rankedSeasonStandings   RankedSeasonStanding[]
  rankedSeasonPrizeGrants RankedSeasonPrizeGrant[]
  rankedSeasonPlacements  UserRankedSeasonPlacement[]
  clanMembership          ClanMember?
  clansOwned              Clan[]                       @relation("ClanOwner")
  clanJoinRequests        ClanJoinRequest[]
  coinPackCheckouts       CoinPackCheckout[]
  friendRequestsSent      Friendship[]                 @relation("FriendRequester")
  friendRequestsReceived  Friendship[]                 @relation("FriendAddressee")
  directMessagesSent      DirectMessage[]              @relation("DirectMessageSender")
  directMessagesReceived  DirectMessage[]              @relation("DirectMessageRecipient")
  smurfSignals            SmurfSignal[]
  accountFingerprints     AccountFingerprint[]
  anticheatReviewCases    AnticheatReviewCase[]        @relation("AnticheatReviewSubject")
  anticheatReviewsResolved AnticheatReviewCase[]       @relation("AnticheatReviewResolver")

  @@index([rank])
  @@index([elo])
  @@index([competitivePoints])
  @@index([level])
  @@index([rankedKills])
  @@index([rankedAssists])
  @@index([rankedMvps])
  @@index([rankedHeadshots])
  @@index([rankedClutches])
  @@index([rankedUtilityDamage])
  @@index([rankedAwpKills])
  @@index([smurfStatus])
  @@index([smurfRiskScore])
  @@index([avatarModerationStatus])
}

model SmurfSignal {
  id         String          @id @default(cuid())
  userId     String
  signalType SmurfSignalType
  score      Int             @default(1)
  metadata   Json            @default("{}")
  resolved   Boolean         @default(false)
  createdAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resolved])
  @@index([signalType, createdAt])
}

model AccountFingerprint {
  id            String   @id @default(cuid())
  userId        String
  ipHash        String
  userAgentHash String
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipHash, userAgentHash])
  @@index([ipHash])
  @@index([userAgentHash])
}

model CoinTransaction {
  id           String              @id @default(cuid())
  userId       String
  amount       Int
  balanceAfter Int
  kind         CoinTransactionKind
  reason       String              @default("")
  metadata     Json?
  createdAt    DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([kind])
}

model MissionDefinition {
  id          String        @id @default(cuid())
  code        String        @unique
  period      MissionPeriod
  metric      MissionMetric
  target      Int
  title       String
  description String        @default("")
  rewardXp    Int           @default(0)
  rewardCoins Int           @default(0)
  icon        String?
  sortOrder   Int           @default(0)
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userMissions UserMission[]

  @@index([period, enabled])
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  missionId   String
  periodKey   String
  progress    Int       @default(0)
  target      Int
  completed   Boolean   @default(false)
  claimed     Boolean   @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission MissionDefinition @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, periodKey])
  @@index([userId, periodKey])
}

model AchievementDefinition {
  id          String            @id @default(cuid())
  code        String            @unique
  metric      AchievementMetric
  threshold   Int
  tier        AchievementTier   @default(BRONZE)
  title       String
  description String            @default("")
  rewardXp    Int               @default(0)
  rewardCoins Int               @default(0)
  icon        String?
  sortOrder   Int               @default(0)
  enabled     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userAchievements UserAchievement[]

  @@index([metric, enabled])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model BattlePassSeason {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  seasonNumber     Int       @default(1)
  maxLevel         Int       @default(50)
  xpPerLevel       Int       @default(1000)
  premiumCostCoins Int       @default(5000)
  startsAt         DateTime  @default(now())
  endsAt           DateTime?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rewards    BattlePassReward[]
  userPasses UserBattlePass[]

  @@index([active])
}

model BattlePassReward {
  id              String               @id @default(cuid())
  seasonId        String
  level           Int
  track           BattlePassTrack
  rewardType      BattlePassRewardType
  amountCoins     Int                  @default(0)
  catalogSkinId   String?
  agentDefIndex   Int?
  stickerDefIndex Int?
  label           String
  icon            String?
  createdAt       DateTime             @default(now())

  season BattlePassSeason      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  claims UserBattlePassClaim[]

  @@unique([seasonId, level, track])
  @@index([seasonId])
}

model UserBattlePass {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  xp        Int      @default(0)
  level     Int      @default(1)
  premium   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  season BattlePassSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId])
}

model UserBattlePassClaim {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  claimedAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward BattlePassReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
}

model RankedSeason {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  seasonNumber Int
  description  String             @default("")
  startsAt     DateTime
  endsAt       DateTime?
  resetAt      DateTime?
  status       RankedSeasonStatus @default(DRAFT)
  active       Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  prizes        RankedSeasonPrize[]
  standings     RankedSeasonStanding[]
  prizeGrants   RankedSeasonPrizeGrant[]
  matchSessions RankedMatchSession[]
  placements    UserRankedSeasonPlacement[] @relation("SeasonPlacements")
  seededFrom    UserRankedSeasonPlacement[] @relation("PreviousSeasonPlacements")

  @@index([active])
  @@index([status])
  @@index([seasonNumber])
  @@index([startsAt])
}

model RankedSeasonPrize {
  id              String                 @id @default(cuid())
  seasonId        String
  position        Int
  sortOrder       Int                    @default(0)
  rewardType      RankedSeasonRewardType
  amountCoins     Int                    @default(0)
  pixAmountCents  Int                    @default(0)
  catalogSkinId   String?
  agentDefIndex   Int?
  stickerDefIndex Int?
  label           String                 @default("")
  enabled         Boolean                @default(true)
  highlight       Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  season      RankedSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  catalogSkin CsgoSkinCatalog? @relation(fields: [catalogSkinId], references: [id], onDelete: SetNull)

  @@index([seasonId])
  @@index([seasonId, position])
}

model RankedSeasonStanding {
  id                String   @id @default(cuid())
  seasonId          String
  userId            String
  position          Int
  nickname          String
  avatarUrl         String?
  elo               Int
  competitivePoints Int
  rankedWins        Int
  rankedLosses      Int
  rankedKills       Int
  rankedDeaths      Int
  kd                Float    @default(0)
  createdAt         DateTime @default(now())

  season RankedSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId, position])
  @@index([userId])
}

model UserRankedSeasonPlacement {
  id                       String   @id @default(cuid())
  userId                   String
  seasonId                 String
  previousSeasonId         String?
  previousPosition         Int?
  previousElo              Int?
  previousKd               Float?
  previousPoints           Int?
  previousWins             Int?
  previousKills            Int?
  totalPreviousParticipants Int     @default(0)
  placementApplied         Boolean  @default(false)
  seededElo                Int?
  seededPoints             Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  season           RankedSeason  @relation("SeasonPlacements", fields: [seasonId], references: [id], onDelete: Cascade)
  previousSeason   RankedSeason? @relation("PreviousSeasonPlacements", fields: [previousSeasonId], references: [id], onDelete: SetNull)

  @@unique([userId, seasonId])
  @@index([seasonId])
  @@index([userId])
}

model RankedSeasonPrizeGrant {
  id               String                 @id @default(cuid())
  seasonId         String
  userId           String
  position         Int
  prizeId          String
  rewardType       RankedSeasonRewardType
  amountCoins      Int                    @default(0)
  pixAmountCents   Int                    @default(0)
  catalogSkinId    String?
  agentDefIndex    Int?
  stickerDefIndex  Int?
  label            String                 @default("")
  grantedAt        DateTime               @default(now())
  grantedByAdminId String?
  pixPayoutStatus  RankedSeasonPixPayoutStatus?
  pixPayoutNote    String                 @default("")
  pixContactedAt   DateTime?
  pixPaidAt        DateTime?

  season RankedSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId, prizeId])
  @@index([seasonId])
  @@index([userId])
}

model Punishment {
  id          String          @id @default(cuid())
  userId      String
  adminId     String
  type        PunishmentType
  scope       PunishmentScope @default(PLATFORM)
  serverName  String          @default("")
  reason      String
  notes       String          @default("")
  active      Boolean         @default(true)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  revokedAt   DateTime?
  revokedById String?

  user      User  @relation("UserPunishments", fields: [userId], references: [id], onDelete: Cascade)
  admin     User  @relation("PunishmentAdmin", fields: [adminId], references: [id])
  revokedBy User? @relation("PunishmentRevoker", fields: [revokedById], references: [id])

  @@index([userId, active])
  @@index([type, active])
  @@index([createdAt])
}

model AnticheatReviewCase {
  id           String                  @id @default(cuid())
  userId       String?
  steamId      String                  @default("")
  nickname     String                  @default("")
  matchId      String?
  demoUrl      String?
  reason       String
  evidence     Json?
  severity     Int                     @default(2)
  status       AnticheatReviewStatus   @default(PENDING)
  adminNotes   String                  @default("")
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user       User? @relation("AnticheatReviewSubject", fields: [userId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("AnticheatReviewResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([steamId])
  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  summary    String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  title        String
  body         String
  titleKey     String?
  bodyKey      String?
  params       Json?
  translations Json?
  read         Boolean          @default(false)
  type         NotificationType @default(SYSTEM)
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model UserNotificationPreferences {
  userId          String  @id
  emailNewsletter Boolean @default(true)
  inAppMatch      Boolean @default(true)
  inAppSocial     Boolean @default(true)
  inAppPromo      Boolean @default(true)
  inAppSystem     Boolean @default(true)
  browserPush     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameMode {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  accent       String
  tagline      String         @default("")
  description  String         @default("")
  iconKey      String         @default("Crosshair")
  sortOrder    Int            @default(0)
  translations Json?
  rooms        GameModeRoom[]
  lobbyRooms   LobbyRoom[]
}

model GameModeRoom {
  id           String @id @default(cuid())
  gameModeId   String
  name         String
  map          String
  players      Int    @default(0)
  slots        Int
  ping         Int    @default(0)
  sortOrder    Int    @default(0)
  translations Json?

  gameMode  GameMode   @relation(fields: [gameModeId], references: [id], onDelete: Cascade)
  lobbyRoom LobbyRoom?

  @@index([gameModeId])
}

model LobbyRoom {
  id            String    @id @default(cuid())
  hostUserId    String
  gameModeId    String
  catalogRoomId String?   @unique
  isSystem      Boolean   @default(false)
  name          String
  map           String
  slots         Int
  region        String    @default("BR")
  visibility    String    @default("public")
  passwordHash  String?
  settings      Json      @default("{}")
  status        String    @default("open")
  ping          Int       @default(25)
  matchId       String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  host        User                @relation("LobbyHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  gameMode    GameMode            @relation(fields: [gameModeId], references: [id], onDelete: Cascade)
  catalogRoom GameModeRoom?       @relation(fields: [catalogRoomId], references: [id], onDelete: Cascade)
  members     LobbyMember[]
  joinQueue   LobbyJoinQueue[]
  rankedMatch RankedMatchSession?

  @@index([status])
  @@index([gameModeId])
  @@index([hostUserId])
  @@index([createdAt])
  @@index([isSystem])
}

model RankedParty {
  id           String   @id @default(cuid())
  leaderUserId String
  inviteCode   String   @unique @default(cuid())
  status       String   @default("open")
  name         String?
  region       String   @default("BR")
  visibility   String   @default("public")
  passwordHash String?
  minLevel     Int      @default(1)
  maxLevel     Int      @default(20)
  mapPool      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leader             User                  @relation("RankedPartyLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  members            RankedPartyMember[]
  challengesSent     RankedChallenge[]     @relation("ChallengeFrom")
  challengesReceived RankedChallenge[]     @relation("ChallengeTo")
  matchSessionsAsA   RankedMatchSession[]  @relation("MatchPartyA")
  matchSessionsAsB   RankedMatchSession[]  @relation("MatchPartyB")
  queueEntry         RankedQueueEntry?
  activities         RankedPartyActivity[]
  messages           RankedPartyMessage[]

  @@index([leaderUserId])
  @@index([status])
}

model RankedPartyActivity {
  id            String   @id @default(cuid())
  partyId       String
  type          String
  nickname      String
  actorNickname String?
  createdAt     DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
}

model RankedPartyMessage {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  nickname  String
  body      String
  createdAt DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
}

model RankedPartyMember {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  slotIndex Int
  joinedAt  DateTime @default(now())

  party RankedParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@unique([partyId, slotIndex])
  @@unique([userId])
  @@index([partyId])
}

model RankedChallenge {
  id          String    @id @default(cuid())
  fromPartyId String
  toPartyId   String
  status      String    @default("pending")
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  fromParty    RankedParty         @relation("ChallengeFrom", fields: [fromPartyId], references: [id], onDelete: Cascade)
  toParty      RankedParty         @relation("ChallengeTo", fields: [toPartyId], references: [id], onDelete: Cascade)
  matchSession RankedMatchSession?

  @@index([fromPartyId])
  @@index([toPartyId])
  @@index([status])
}

model RankedMatchSession {
  id              String    @id @default(cuid())
  challengeId     String?   @unique
  lobbyRoomId     String?   @unique
  seasonId        String?
  matchSource     String    @default("challenge")
  teamSize        Int       @default(5)
  partyAId        String
  partyBId        String
  status          String    @default("accepting")
  csgoMatchId     String?
  csgoServerId    String?
  selectedMap     String?
  serverHost      String?
  serverPort      Int?
  vetoData        Json?
  voteEndsAt      DateTime?
  scoreTeamA      Int?
  scoreTeamB      Int?
  winnerTeam      String?
  liveStartedAt   DateTime?
  matchFinishedAt DateTime?
  durationSec     Int?
  resultSyncedAt  DateTime?
  demoUrl         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  challenge   RankedChallenge?        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  lobbyRoom   LobbyRoom?              @relation(fields: [lobbyRoomId], references: [id], onDelete: SetNull)
  season      RankedSeason?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  partyA      RankedParty             @relation("MatchPartyA", fields: [partyAId], references: [id], onDelete: Cascade)
  partyB      RankedParty             @relation("MatchPartyB", fields: [partyBId], references: [id], onDelete: Cascade)
  acceptances RankedMatchAcceptance[]
  mapVotes    RankedMapVote[]
  playerStats RankedMatchPlayerStat[]
  rounds      RankedMatchRound[]
  highlights  RankedMatchHighlight[]
  deaths      RankedMatchDeath[]

  @@index([partyAId])
  @@index([partyBId])
  @@index([status])
  @@index([lobbyRoomId])
  @@index([csgoServerId])
  @@index([seasonId])
}

model RankedMatchAcceptance {
  id         String    @id @default(cuid())
  sessionId  String
  userId     String
  accepted   Boolean   @default(false)
  acceptedAt DateTime?

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model RankedMapVote {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  map       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model RankedMatchPlayerStat {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  steamId   String
  team      String
  kills          Int      @default(0)
  deaths         Int      @default(0)
  assists        Int      @default(0)
  score          Int      @default(0)
  mvp            Int      @default(0)
  won            Boolean  @default(false)
  headshots      Int      @default(0)
  damage         Int      @default(0)
  utilityDamage  Int      @default(0)
  enemiesFlashed Int      @default(0)
  clutchesWon    Int      @default(0)
  entryKills     Int      @default(0)
  awpKills       Int      @default(0)
  createdAt      DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([sessionId, steamId])
  @@index([sessionId])
  @@index([userId])
  @@index([steamId])
}

model RankedMatchRound {
  id          String   @id @default(cuid())
  sessionId   String
  roundNumber Int
  winnerTeam  String?
  reason      String?
  bombPlanted Boolean  @default(false)
  createdAt   DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roundNumber])
  @@index([sessionId])
}

model RankedMatchHighlight {
  id          String             @id @default(cuid())
  sessionId   String
  steamId     String
  userId      String?
  type        MatchHighlightType
  roundNumber Int?
  detail      String             @default("")
  createdAt   DateTime           @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model RankedMatchDeath {
  id            String   @id @default(cuid())
  sessionId     String
  roundNumber   Int      @default(0)
  victimSteamId String
  killerSteamId String?
  weapon        String?
  headshot      Boolean  @default(false)
  victimTeam    String?
  x             Float    @default(0)
  y             Float    @default(0)
  z             Float    @default(0)
  createdAt     DateTime @default(now())

  session RankedMatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, roundNumber])
}

model LobbyMember {
  id          String   @id @default(cuid())
  lobbyRoomId String
  userId      String
  slotIndex   Int
  isReady     Boolean  @default(false)
  joinedAt    DateTime @default(now())

